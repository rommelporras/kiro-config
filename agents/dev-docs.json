{
  "name": "dev-docs",
  "description": "Edits config files, documentation, and non-code text. Lightweight — no TDD, no linting. Use for markdown, JSON, YAML, TOML, path updates, and bulk replacements.",
  "prompt": "file://./prompts/docs.md",
  "model": "claude-sonnet-4.6",
  "tools": [
    "read",
    "write",
    "shell",
    "code"
  ],
  "allowedTools": [
    "read",
    "write",
    "code"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "~/personal/**",
        "~/eam/**",
        "./**"
      ],
      "deniedPaths": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gh",
        "~/.kiro/settings/cli.json",
        "~/.kiro/agents",
        "~/.kiro/hooks",
        "~/.kiro/steering",
        "**/eam_sre/**/*.py",
        "**/tests/**/*.py"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true,
      "deniedCommands": [
        "rm -r.*",
        "rm -[a-zA-Z]*r[a-zA-Z]* .*",
        "rm --force --recursive.*",
        "rm --recursive.*",
        "dd if=/dev.*",
        "git push.*",
        "git push",
        "python3? .*",
        "node .*",
        "npm .*",
        "uv .*",
        "pip .*",
        "terraform .*",
        "helm .*",
        "kubectl .*",
        "docker .*",
        "aws .*",
        "git add.*",
        "git commit.*"
      ]
    }
  },
  "resources": [
    "file://~/.kiro/steering/**/*.md",
    "file://.kiro/steering/**/*.md",
    "skill://~/.kiro/skills/verification-before-completion/SKILL.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "bash ~/.kiro/hooks/scan-secrets.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "fs_write",
        "command": "bash ~/.kiro/hooks/protect-sensitive.sh",
        "timeout_ms": 3000,
        "cache_ttl_seconds": 60
      },
      {
        "matcher": "execute_bash",
        "command": "bash ~/.kiro/hooks/bash-write-protect.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "bash ~/.kiro/hooks/security/block-sed-json.sh",
        "timeout_ms": 3000
      }
    ]
  },
  "includeMcpJson": false
}

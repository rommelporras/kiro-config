{
  "name": "dev-docs",
  "description": "Edits config files, documentation, and non-code text. Lightweight — no TDD, no linting. Use for markdown, JSON, YAML, TOML, path updates, and bulk replacements.",
  "prompt": "file://./prompts/dev-docs.md",
  "model": "claude-sonnet-4.6",
  "tools": [
    "read",
    "write",
    "shell",
    "code"
  ],
  "allowedTools": [
    "read",
    "write",
    "code",
    "shell"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "~/personal/**",
        "~/eam/**",
        "./**"
      ],
      "deniedPaths": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gh",
        "~/.kiro/settings/cli.json",
        "~/.kiro/agents",
        "~/.kiro/hooks",
        "~/.kiro/steering",
        "**/eam_sre/**/*.py",
        "**/tests/**/*.py"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true,
      "deniedCommands": [
        "rm -r.*",
        "rm -[a-zA-Z]*r[a-zA-Z]* .*",
        "rm --force --recursive.*",
        "rm --recursive.*",
        "dd if=/dev.*",
        "git push.*",
        "git push",
        "npm install.*",
        "npm i .*",
        "npm uninstall.*",
        "npm remove.*",
        "npm rm.*",
        "npm publish.*",
        "npm update.*",
        "npm run.*",
        "npm init.*",
        "npm ci.*",
        "npm link.*",
        "npm exec.*",
        "npm pkg set.*",
        "npm pkg delete.*",
        "npm pkg fix.*",
        "npm cache clean.*",
        "npm cache add.*",
        "npm cache npx rm.*",
        "npm version.*",
        "npm prune.*",
        "npm dedupe.*",
        "npm unpublish.*",
        "npm shrinkwrap.*",
        "npm deprecate.*",
        "npm dist-tag.*",
        "npm owner.*",
        "npm star.*",
        "uv add.*",
        "uv remove.*",
        "uv sync.*",
        "uv lock.*",
        "uv run.*",
        "uv pip install.*",
        "uv pip uninstall.*",
        "uv init.*",
        "uv venv.*",
        "uv tool run.*",
        "uv tool install.*",
        "uv tool upgrade.*",
        "uv tool uninstall.*",
        "uv tool update-shell.*",
        "uv pip compile.*",
        "uv cache clean.*",
        "uv cache prune.*",
        "pip install.*",
        "pip uninstall.*",
        "pip download.*",
        "pip cache purge.*",
        "pip cache remove.*",
        "pip config set.*",
        "pip wheel.*",
        "terraform .*",
        "helm .*",
        "kubectl .*",
        "docker .*",
        "aws .*",
        "git add.*",
        "git commit.*"
      ]
    }
  },
  "resources": [
    "file://~/.kiro/steering/**/*.md",
    "file://.kiro/steering/**/*.md",
    "skill://~/.kiro/skills/verification-before-completion/SKILL.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "bash ~/.kiro/hooks/scan-secrets.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "fs_write",
        "command": "bash ~/.kiro/hooks/protect-sensitive.sh",
        "timeout_ms": 3000,
        "cache_ttl_seconds": 60
      },
      {
        "matcher": "execute_bash",
        "command": "bash ~/.kiro/hooks/bash-write-protect.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "bash ~/.kiro/hooks/security/block-sed-json.sh",
        "timeout_ms": 3000
      }
    ]
  },
  "includeMcpJson": false
}

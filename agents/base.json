{
  "name": "base",
  "description": "Standalone fallback agent with read-only tools pre-approved. Use when you want to work without the orchestrator pattern.",
  "prompt": null,
  "welcomeMessage": "Base agent active — global steering, 12 skills, security hooks, and self-learning knowledge system loaded. Run /context show to verify.",
  "mcpServers": {},
  "tools": [
    "read",
    "write",
    "shell",
    "aws",
    "introspect",
    "grep",
    "glob",
    "web_fetch",
    "web_search",
    "@context7",
    "@awslabs.aws-diagram-mcp-server",
    "knowledge"
  ],
  "toolAliases": {},
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "introspect",
    "web_fetch",
    "web_search",
    "@context7",
    "@awslabs.aws-diagram-mcp-server",
    "knowledge"
  ],
  "resources": [
    "file://~/.kiro/steering/**/*.md",
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/*/SKILL.md",
    "skill://~/.kiro/skills/*/SKILL.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "bash ~/.kiro/hooks/scan-secrets.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "fs_write",
        "command": "bash ~/.kiro/hooks/protect-sensitive.sh",
        "timeout_ms": 3000,
        "cache_ttl_seconds": 60
      },
      {
        "matcher": "execute_bash",
        "command": "bash ~/.kiro/hooks/bash-write-protect.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "bash ~/.kiro/hooks/security/block-sed-json.sh",
        "timeout_ms": 3000
      }
    ],
    "userPromptSubmit": [
      {
        "command": "bash ~/.kiro/hooks/feedback/context-enrichment.sh",
        "description": "Inject relevant knowledge rules into agent context",
        "timeout_ms": 5000
      },
      {
        "command": "bash ~/.kiro/hooks/feedback/correction-detect.sh",
        "description": "Detect user corrections and auto-capture to knowledge base",
        "timeout_ms": 3000
      }
    ],
    "stop": [
      {
        "command": "bash ~/.kiro/hooks/notify.sh",
        "description": "Play notification sound when agent finishes"
      }
    ],
    "agentSpawn": [
      {
        "command": "bash ~/.kiro/hooks/workspace-context.sh",
        "description": "Inject workspace context at session start",
        "timeout_ms": 5000
      }
    ]
  },
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "~/.kiro",
        "~/personal",
        "~/eam"
      ],
      "deniedPaths": [
        "~/.ssh",
        "~/.aws/credentials",
        "~/.gnupg",
        "~/.config/gh",
        "~/.kiro/settings/cli.json"
      ]
    },
    "fs_write": {
      "allowedPaths": [
        "~/personal",
        "~/eam"
      ],
      "deniedPaths": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gh",
        "~/.kiro/settings/cli.json",
        "~/.kiro/agents",
        "~/.kiro/hooks",
        "~/.kiro/steering"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        "git add .*",
        "git commit .*",
        "git stash.*",
        "git checkout .*",
        "git switch .*",
        "git branch.*",
        "readlink .*",
        "find .*"
      ],
      "deniedCommands": [
        "rm .*",
        "git push .*",
        "git push",
        "chmod -R 777 /",
        "mkfs\\\\.",
        "dd if=/dev",
        "> /dev/sd",
        "> /dev/nvme"
      ]
    },
    "use_aws": {
      "autoAllowReadonly": true
    }
  },
  "includeMcpJson": true,
  "model": null
}
